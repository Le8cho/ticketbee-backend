# APP
APP_ENV=development
DEBUG_MODE=False

# AZURE SQL DATABASE
DATABASE_URL=mssql+aioodbc://usuario:password@tu-servidor.database.windows.net:1433/tu_base_de_datos?driver=ODBC+Driver+18+for+SQL+Server

# AZURE COMMUNICATION SERVICES (ACS) - envio de emails de notificacion
ACS_CONNECTION_STR=endpoint=https://tu-recurso.communication.azure.com/;accesskey=dummy_access_key
ACS_FROM_ADDRESS=DoNotReply@dummy.azurecomm.net

# AZURE SERVICE BUS
AZURE_SERVICEBUS_CONNECTION_STR=
AZURE_SERVICEBUS_TOPIC=

# AZURE BLOB STORAGE
AZURE_STORAGE_CONNECTION_STR=
AZURE_STORAGE_CONTAINER=
AZURE_STORAGE_CONTAINER_DEVICES=
AZURE_STORAGE_CONTAINER_TICKETS=

# SUPABASE AUTH
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_ALGORITHM=ES256

# CORS (origenes separados por coma, sin espacios)
CORS_ORIGINS=http://localhost:5173
