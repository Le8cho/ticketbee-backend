# Base de datos — Supabase (PostgreSQL)
# Usar el host del pooler (no el host directo, que solo tiene IPv6)
DATABASE_URL=postgresql+asyncpg://postgres.[ref]:[password]@aws-1-us-east-2.pooler.supabase.com:5432/postgres

# JWT
SECRET_KEY=changeme_generate_a_strong_key_min_32_chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
APP_ENV=development

# Azure Service Bus (dejar vacío en desarrollo local)
AZURE_SERVICEBUS_CONNECTION_STR=
AZURE_SERVICEBUS_TOPIC=

# Azure Blob Storage (dejar vacío en desarrollo local)
AZURE_STORAGE_CONNECTION_STR=
AZURE_STORAGE_CONTAINER=
